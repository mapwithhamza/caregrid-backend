# ============================================================
# CareGrid Vector Agent — Environment Variables (TEMPLATE)
#
# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.
# Rotate any key that has been exposed (chat history, screenshots, etc.).
# ============================================================

# ------------------------------------------------------------
# Tavily (optional external web verification)
# ------------------------------------------------------------
# Get an API key at https://app.tavily.com — keys start with `tvly-`.
TAVILY_API_KEY=tvly-your-real-key-here

# Two equivalent flags. Set EITHER one to true to enable Tavily.
# settings.py reads both via AliasChoices; the canonical name is
# TAVILY_ENABLED but ENABLE_TAVILY is also accepted.
TAVILY_ENABLED=false
ENABLE_TAVILY=false

# Search depth: "basic" (1 search, ~1 credit) or "advanced" (~4 credits).
TAVILY_DEFAULT_DEPTH=basic

# Two equivalent caps on how many top recommendations Tavily verifies.
# Canonical name is TAVILY_MAX_WEB_VERIFIED; TAVILY_MAX_RESULTS is also
# accepted.
TAVILY_MAX_WEB_VERIFIED=2
TAVILY_MAX_RESULTS=2

TAVILY_CACHE_DIR=data/tavily_cache

# ------------------------------------------------------------
# Databricks Mosaic AI Vector Search
# ------------------------------------------------------------
# Two equivalent flags — set either one to true to enable.
VECTOR_SEARCH_ENABLED=false
ENABLE_VECTOR_SEARCH=false

DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_personal_access_token
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=caregrid

# Source Delta table that the vector index syncs from.
VECTOR_SOURCE_TABLE=workspace.default.caregrid_vector_source

# Endpoint name. Three equivalent env vars accepted (canonical first):
#   VECTOR_SEARCH_ENDPOINT  (canonical, used inside the package)
#   DATABRICKS_VECTOR_SEARCH_ENDPOINT  (legacy long alias)
#   DATABRICKS_VECTOR_ENDPOINT         (short alias used by Stage 17 docs)
VECTOR_SEARCH_ENDPOINT=caregrid-vector-endpoint
DATABRICKS_VECTOR_SEARCH_ENDPOINT=caregrid-vector-endpoint
DATABRICKS_VECTOR_ENDPOINT=caregrid-vector-endpoint

# Fully-qualified index name. Three equivalent env vars accepted:
#   VECTOR_SEARCH_INDEX            (canonical)
#   DATABRICKS_VECTOR_INDEX_NAME   (legacy long alias)
#   DATABRICKS_VECTOR_INDEX        (short alias used by Stage 17 docs)
VECTOR_SEARCH_INDEX=workspace.default.caregrid_vector_index
DATABRICKS_VECTOR_INDEX_NAME=workspace.default.caregrid_vector_index
DATABRICKS_VECTOR_INDEX=workspace.default.caregrid_vector_index

# ------------------------------------------------------------
# MLflow (optional)
# ------------------------------------------------------------
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=caregrid_vector_agent

# ------------------------------------------------------------
# Agent behaviour
# ------------------------------------------------------------
MAX_RESULTS=10
TRUST_SCORE_THRESHOLD=0.6

# ------------------------------------------------------------
# Paths
# ------------------------------------------------------------
LOCAL_DATA_PATH=data
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
VECTOR_SOURCE_DIR=data/vector_source
OUTPUTS_DIR=data/outputs
AUDIT_LOG_PATH=data/outputs/audit_log.jsonl
