# =============================================================================
# CareGrid India backend .env example
# =============================================================================
# Copy to `.env` and fill in real values for your environment.
# `.env` is git-ignored. Never commit real tokens or API keys.
# =============================================================================

# Core backend
APP_NAME=CareGrid India API
ENVIRONMENT=development
DATA_DIR=./data

# -----------------------------------------------------------------------------
# Standalone CareGrid Vector Agent — optional Databricks Mosaic AI Vector Search
# -----------------------------------------------------------------------------
# When both `ENABLE_VECTOR_SEARCH` and the four `DATABRICKS_*` values are set,
# the upgraded `/agent/recommend` route will retrieve candidates from the live
# vector index and merge them with local CSV results. Missing values do NOT
# crash the backend — the agent falls back to local-only retrieval.
VECTOR_SEARCH_ENABLED=false
ENABLE_VECTOR_SEARCH=false

DATABRICKS_HOST=
DATABRICKS_TOKEN=

VECTOR_SOURCE_TABLE=workspace.default.caregrid_vector_source
VECTOR_SEARCH_ENDPOINT=caregrid-vector-endpoint
VECTOR_SEARCH_INDEX=workspace.default.caregrid_vector_index
DATABRICKS_VECTOR_ENDPOINT=caregrid-vector-endpoint
DATABRICKS_VECTOR_INDEX=workspace.default.caregrid_vector_index

# -----------------------------------------------------------------------------
# Standalone CareGrid Vector Agent — optional Tavily web verification
# -----------------------------------------------------------------------------
# Tavily is only contacted for the top `TAVILY_MAX_WEB_VERIFIED` recommendations
# after ranking. Each verification costs ~1 credit (basic depth) or ~2 (demo).
# Missing key ⇒ `verification_status="skipped"`; backend never crashes.
TAVILY_ENABLED=false
ENABLE_TAVILY=false
TAVILY_API_KEY=
TAVILY_DEFAULT_DEPTH=basic
TAVILY_MAX_WEB_VERIFIED=2
TAVILY_MAX_RESULTS=2

# -----------------------------------------------------------------------------
# Local CSV path used by the standalone agent when called outside the backend
# (e.g. via run_agent_demo.py). When called *through* the backend, the
# dataframe loaded by `app.data_loader.data_store` is reused — no second read.
# -----------------------------------------------------------------------------
LOCAL_DATA_PATH=./data/caregrid_backend_export_full.csv
